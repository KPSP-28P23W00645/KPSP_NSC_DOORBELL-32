"data\": {\n                    \"comment\": \"image1\",\n                    \"py_ver\": \"1. Python2\",\n                    \"script\": \"import cv2\\nimport urllib2\\nimport numpy as np\\nimport base64\\n\\n# Initialize the state (do not write payload = {})\\npayload[\\\"have_img\\\"] = False\\n\\n# Your ESP32-CAM IP\\nurl = \\\"http://192.168.1.33/capture.jpg\\\"\\n\\ntry:\\n\\t# 1. Fetch and decode the image using Python 2's urllib2\\n\\tresponse = urllib2.urlopen(url, timeout=3)\\n\\timg_array = np.asarray(bytearray(response.read()), dtype=np.uint8)\\n\\timg = cv2.imdecode(img_array, cv2.IMREAD_COLOR)\\n\\t\\n\\tif img is not None:\\n\\t\\t# 2. Resize for speed\\n\\t\\t# img = cv2.resize(img, (320, 240))\\n\\t\\t\\n\\t\\t# 3. Convert to Base64 string (Python 2 compatible)\\n\\t\\t_, buffer = cv2.imencode('.jpg', img)\\n\\t\\tjpg_as_text = base64.b64encode(buffer.tostring())\\n\\t\\t\\n\\t\\t# 4. Save to payload as a string\\n\\t\\tpayload[\\\"img_b64\\\"] = \\\"data:image/jpeg;base64,\\\" + jpg_as_text\\n\\t\\tpayload[\\\"have_img\\\"] = True\\n\\t\\tprint \\\"Image captured and converted successfully!\\\"\\n\\telse:\\n\\t\\tprint \\\"Error: Could not decode image\\\"\\n\\t\\tpayload[\\\"have_img\\\"] = False\\n\\t\\t\\nexcept Exception as e:\\n\\tprint \\\"Error: \\\" + str(e)\\n\\tpayload[\\\"have_img\\\"] = False\",\n                    \"tmp_path\": \"C:/Users/Patter/image1.py\",\n                    \"widget_state\": {\n                        \"editor_setting\": {\n                            \"autoComplete\": {\n                                \"caseSensitivity\": true,\n                                \"enable\": true,\n                                \"threshold\": 3\n                            },\n                            \"indent\": {\n                                \"enable\": true\n                            },\n                            \"theme\": \"Material Dark\",\n                            \"whitespace\": {\n                        